{
  "$schema": "https://opencode.ai/schemas/agent-metadata.json",
  "schema_version": "1.0.0",
  "description": "Centralized metadata for python-backend Python agents",
  "agents": {
    "python-expert": {
      "id": "python-expert",
      "name": "Python Expert",
      "category": "core",
      "type": "agent",
      "version": "1.0.0",
      "author": "opencode",
      "tags": ["python", "pytest", "fastapi", "pyproject"],
      "dependencies": [
        "subagent:python-coder",
        "subagent:python-reviewer",
        "subagent:python-tester",
        "subagent:python-scout",
        "skill:python-fundamentals",
        "skill:python-fastapi",
        "skill:python-backend",
        "skill:python-testing-general",
        "skill:python-asyncio",
        "skill:python-type-hints",
        "context:python-standards",
        "context:python-patterns",
        "context:python-security"
      ]
    }
  },
  "subagents": {
    "python-coder": {
      "id": "python-coder",
      "name": "Python Coder",
      "category": "development",
      "type": "subagent",
      "version": "1.0.0",
      "author": "opencode",
      "tags": ["coding", "implementation", "generation"],
      "dependencies": [
        "skill:python-fundamentals",
        "context:python-standards"
      ]
    },
    "python-reviewer": {
      "id": "python-reviewer",
      "name": "Python Reviewer",
      "category": "quality",
      "type": "subagent",
      "version": "1.0.0",
      "author": "opencode",
      "tags": ["review", "quality", "best-practices"],
      "dependencies": [
        "skill:python-fundamentals",
        "context:python-standards"
      ]
    },
    "python-tester": {
      "id": "python-tester",
      "name": "Python Tester",
      "category": "testing",
      "type": "subagent",
      "version": "1.0.0",
      "author": "opencode",
      "tags": ["testing", "pytest", "coverage"],
      "dependencies": [
        "skill:python-testing-general",
        "skill:python-testing-deep",
        "context:python-standards"
      ]
    },
    "python-scout": {
      "id": "python-scout",
      "name": "Python Scout",
      "category": "exploration",
      "type": "subagent",
      "version": "1.0.0",
      "author": "opencode",
      "tags": ["context", "discovery", "exploration"],
      "dependencies": []
    }
  },
  "skills": {
    "python-fundamentals": {
      "id": "python-fundamentals",
      "name": "Python Fundamentals",
      "version": "1.0.0",
      "triggers": ["*.py", "python", "dataclass", "async", "type hint"]
    },
    "python-fastapi": {
      "id": "python-fastapi",
      "name": "Python FastAPI",
      "version": "1.0.0",
      "triggers": ["fastapi", "pydantic", "uvicorn", "endpoint", "api"]
    },
    "python-backend": {
      "id": "python-backend",
      "name": "Python Backend",
      "version": "1.0.0",
      "triggers": ["sqlalchemy", "database", "orm", "migration"]
    },
    "python-testing-general": {
      "id": "python-testing-general",
      "name": "Python Testing General",
      "version": "1.0.0",
      "triggers": ["pytest", "test", "mock", "fixture", "coverage"]
    },
    "python-testing-deep": {
      "id": "python-testing-deep",
      "name": "Python Testing Deep",
      "version": "1.0.0",
      "triggers": ["hypothesis", "snapshot", "property-based"]
    },
    "python-asyncio": {
      "id": "python-asyncio",
      "name": "Python Asyncio",
      "version": "1.0.0",
      "triggers": ["async", "await", "asyncio", "concurrent"]
    },
    "python-type-hints": {
      "id": "python-type-hints",
      "name": "Python Type Hints",
      "version": "1.0.0",
      "triggers": ["type hint", "typing", "Protocol", "mypy", "pyright"]
    },
    "python-package-management": {
      "id": "python-package-management",
      "name": "Python Package Management",
      "version": "1.0.0",
      "triggers": ["uv", "pip", "package", "dependency", "pyproject"]
    },
    "python-tooling": {
      "id": "python-tooling",
      "name": "Python Tooling",
      "version": "1.0.0",
      "triggers": ["docker", "ci", "cd", "github", "profile", "optimize"]
    },
    "python-fundamentals-313": {
      "id": "python-fundamentals-313",
      "name": "Python Fundamentals 3.13",
      "version": "1.0.0",
      "triggers": ["3.13", "free-threading", "jit", "pattern matching"]
    }
  }
}
